# 复制本文件为 .env 并填写实际值（项目只读取 .env，不会读 .env.example）
# 例如：cp .env.example .env  或  copy .env.example .env

# 数据库
DB_HOST=127.0.0.1
DB_NAME=ctlp
DB_USER=root
DB_PASS=
DB_PORT=3306

# SMTP（注册验证码、找回密码邮件）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=CTLP
